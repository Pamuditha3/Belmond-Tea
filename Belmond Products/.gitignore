# ==========================================
# Dependency Directories (Crucial for Monorepos)
# ==========================================
node_modules/
**/node_modules/

# ==========================================
# Environment Variables & Secrets
# ==========================================
.env
.env.local
.env.*.local
**/.env
**/.env.local

# ==========================================
# Backend Specific
# ==========================================
# Ignore user-uploaded files/images in the backend
backend/uploads/*
# Keep the directory structure but ignore files inside
!backend/uploads/.gitkeep

# ==========================================
# Frontend/Build Production Outputs
# ==========================================
dist/
build/
**/dist/
**/build/

# ==========================================
# Logs and Debugging
# ==========================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# System & Editor Files
# ==========================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?